rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if email is verified
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }
    
    // Helper function to check if the user owns the document
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Helper function to check if the requesting user is an admin
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }
    
    // Helper function to validate profile data structure
    function isValidProfileData() {
      let data = request.resource.data;
      return data.keys().hasAll(['uid', 'firstName', 'lastName', 'studentId', 'course', 'major', 'year', 'section', 'profileCompleted', 'mustChangePassword', 'role', 'createdAt', 'updatedAt'])
        && data.uid is string && data.uid.size() > 0
        && data.firstName is string && data.firstName.size() >= 2
        && data.lastName is string && data.lastName.size() >= 2
        && data.studentId is string && data.studentId.size() == 6 && data.studentId.matches('^[0-9]{6}$')
        && data.course is string && data.course.size() >= 2
        && data.major is string && data.major.size() >= 2
        && data.year is number && data.year >= 1 && data.year <= 4
        && data.section is string && data.section.size() >= 1
        && data.profileCompleted is bool
        && data.mustChangePassword is bool
        && data.role in ['admin', 'student'];
    }
    
    // Helper function to ensure UID matches document ID
    function isValidUID(uid) {
      return request.resource.data.uid == uid && uid == request.auth.uid;
    }
    
    // Helper function to validate student ID format (6 digits only)
    function isValidStudentID() {
      return request.resource.data.studentId is string 
        && request.resource.data.studentId.size() == 6
        && request.resource.data.studentId.matches('^[0-9]{6}$');
    }
    
    // Students collection - documents are keyed by uid
    match /students/{uid} {
      // Only admins can create student profiles
      allow create: if isAdmin()
                    && isValidStudentID()
                    && isValidProfileData();
      
      // Any authenticated user can read profiles (needed for studentId duplicate checking)
      allow read: if isAuthenticated();
      
      // Admins can do a full profile update (with validation).
      // Students can only flip mustChangePassword and updatedAt on their own document.
      allow update: if (isAdmin() && isValidProfileData())
                    || (isOwner(uid)
                        && request.resource.data.uid == resource.data.uid
                        && request.resource.data.studentId == resource.data.studentId
                        && request.resource.data.role == resource.data.role
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['mustChangePassword', 'updatedAt']));
      
      // No deletions allowed
      allow delete: if false;
    }
    
    // Admin collection - only admins can read their own document
    match /admin/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // Pre-registered students — only admins can read/write
    match /preregistered_students/{docId} {
      allow read, write: if isAdmin();
    }

    // Schedule — authenticated users can read; only admins can write
    match /schedule/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // News — authenticated users can read; only admins can write
    match /news/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Events — authenticated users can read; only admins can write
    match /events/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Announcements — authenticated users can read; only admins can write
    match /announcements/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Deny all other requests by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
